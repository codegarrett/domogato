# ╔══════════════════════════════════════════════════════════════╗
# ║              Domogato — Environment Configuration           ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Copy this file to .env and fill in the values for your environment.
#
#   cp .env.example .env
#
# For DEVELOPMENT (default docker-compose.yml):
#   docker compose up -d --build
#
# For PRODUCTION (docker-compose.prod.yml):
#   docker compose -f docker-compose.prod.yml up -d --build
#
# Variables marked REQUIRED have no safe default and must be set.
# Variables with defaults shown work out of the box for local dev.
# ──────────────────────────────────────────────────────────────


# ┌──────────────────────────────────────────────────────────────┐
# │  DATABASE (PostgreSQL)                                       │
# └──────────────────────────────────────────────────────────────┘
# The dev stack uses pgvector/pgvector:pg16 with these credentials.
# In production, use a strong password and consider a managed DB.

POSTGRES_DB=projecthub
POSTGRES_USER=projecthub
POSTGRES_PASSWORD=secret               # REQUIRED in prod — use a strong random password


# ┌──────────────────────────────────────────────────────────────┐
# │  REDIS                                                       │
# └──────────────────────────────────────────────────────────────┘
# Used for caching, WebSocket pub/sub, Celery broker, and results.
# In production, set a password. Dev can leave it blank.

REDIS_PASSWORD=                        # Set for production (leave blank for dev)


# ┌──────────────────────────────────────────────────────────────┐
# │  APPLICATION CORE                                            │
# └──────────────────────────────────────────────────────────────┘

# Secret used for JWT signing and session security.
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-random-secret-in-production   # REQUIRED in prod

# JSON array of allowed frontend origins for CORS.
# Dev default includes localhost variants. Prod should be your domain.
ALLOWED_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:3035"]

# Enable debug mode (verbose SQL logging, detailed errors). Never true in prod.
DEBUG=true

# Public URL where users access the app (used in emails, links, etc.)
APP_BASE_URL=http://localhost


# ┌──────────────────────────────────────────────────────────────┐
# │  AUTHENTICATION                                              │
# └──────────────────────────────────────────────────────────────┘
# Two modes are supported:
#   "local"  — built-in email/password auth (no external IdP needed)
#   "oidc"   — OpenID Connect via Keycloak or any OIDC provider
#
# Leave blank to auto-detect: if OIDC_ISSUER_URL is set, uses oidc;
# otherwise falls back to local.

AUTH_MODE=

# The first user to log in with this email becomes system admin.
INITIAL_ADMIN_EMAIL=

# ── Local Auth ──────────────────────────────────────────────────
# Only applies when AUTH_MODE=local.
# Allow new users to self-register via the signup form.
LOCAL_REGISTRATION_ENABLED=true

# ── OIDC / Keycloak ────────────────────────────────────────────
# Only applies when AUTH_MODE=oidc.

# Full issuer URL for your OIDC provider (e.g. Keycloak realm URL)
OIDC_ISSUER_URL=

# Client ID registered in your OIDC provider
OIDC_CLIENT_ID=

# Client secret (only needed for confidential clients)
OIDC_CLIENT_SECRET=

# Audience claim validation (optional — leave blank to skip)
OIDC_AUDIENCE=

# Auto-create user accounts on first OIDC login
OIDC_AUTO_PROVISION=true

# Restrict auto-provisioning to these email domains (comma-separated, blank = all)
OIDC_ALLOWED_DOMAINS=

# Auto-assign new OIDC users to this organization (UUID, optional)
OIDC_DEFAULT_ORG_ID=

# OIDC realm role that grants system admin privileges
OIDC_ADMIN_CLAIM=projecthub-admin

# ── OIDC Frontend Redirects ────────────────────────────────────
# Must match redirect URIs configured in your OIDC provider.
VITE_OIDC_REDIRECT_URI=
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=


# ┌──────────────────────────────────────────────────────────────┐
# │  S3 / MINIO (File Storage)                                  │
# └──────────────────────────────────────────────────────────────┘
# Attachments, avatars, and KB uploads are stored in S3-compatible
# storage. Dev uses the bundled MinIO container. In production you
# can point to AWS S3, DigitalOcean Spaces, etc.

S3_ENDPOINT_URL=http://minio:9000     # Use your S3 endpoint in prod
S3_ACCESS_KEY_ID=minioadmin           # REQUIRED in prod
S3_SECRET_ACCESS_KEY=minioadmin       # REQUIRED in prod
S3_BUCKET_NAME=projecthub-attachments


# ┌──────────────────────────────────────────────────────────────┐
# │  CELERY (Background Tasks)                                  │
# └──────────────────────────────────────────────────────────────┘
# Celery powers background jobs: email digests, embedding generation,
# webhook delivery, daily snapshots. Uses Redis as broker and backend.
# These are auto-constructed from REDIS_PASSWORD in prod compose,
# but you can override them here for custom setups.

CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2


# ┌──────────────────────────────────────────────────────────────┐
# │  AI / LLM CHAT                                              │
# └──────────────────────────────────────────────────────────────┘
# Powers the AI assistant chat. Leave all blank to disable AI features.
#
# Supported providers: "openai", "anthropic", "ollama", "azure"
#
# For OpenAI:
#   LLM_PROVIDER=openai
#   LLM_MODEL=gpt-4o
#   LLM_API_KEY=sk-...
#
# For Anthropic:
#   LLM_PROVIDER=anthropic
#   LLM_MODEL=claude-sonnet-4-20250514
#   LLM_API_KEY=sk-ant-...
#
# For Ollama (self-hosted):
#   LLM_PROVIDER=ollama
#   LLM_MODEL=llama3
#   LLM_BASE_URL=http://ollama:11434/v1
#
# For Azure OpenAI:
#   LLM_PROVIDER=azure
#   AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
#   AZURE_OPENAI_DEPLOYMENT=your-deployment-name
#   LLM_API_KEY=your-azure-key

LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=
LLM_MAX_TOKENS=16384                  # Max tokens per AI response
LLM_CONTEXT_WINDOW=131072             # Model's context window size
LLM_TEMPERATURE=0.7                   # 0.0 = deterministic, 1.0 = creative

# Azure-specific (only when LLM_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_DEPLOYMENT=


# ┌──────────────────────────────────────────────────────────────┐
# │  EMBEDDINGS (Knowledge Base Semantic Search)                 │
# └──────────────────────────────────────────────────────────────┘
# Generates vector embeddings for KB pages and attachments, enabling
# semantic search for the AI agent. Leave blank to disable embeddings.
#
# Supported providers: "openai", "ollama", "azure"
#
# For OpenAI (recommended):
#   EMBEDDING_PROVIDER=openai
#   EMBEDDING_MODEL=text-embedding-3-small
#   EMBEDDING_API_KEY=sk-...
#
# The API key can differ from the LLM key (e.g. different billing).

EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=                   # Override API URL (optional)
EMBEDDING_DIMENSIONS=1536             # Must match your model's output dimensions


# ┌──────────────────────────────────────────────────────────────┐
# │  EMAIL / SMTP                                               │
# └──────────────────────────────────────────────────────────────┘
# Email notifications (instant + digest) and system emails.
# Set SMTP_ENABLED=true and configure a provider to activate.
#
# Example with Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASSWORD=app-password-here
#
# Example with AWS SES:
#   SMTP_HOST=email-smtp.us-east-1.amazonaws.com
#   SMTP_PORT=587
#   SMTP_USER=AKIA...
#   SMTP_PASSWORD=secret...

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@projecthub.local
SMTP_FROM_NAME=Domogato
SMTP_USE_TLS=true


# ┌──────────────────────────────────────────────────────────────┐
# │  FRONTEND                                                    │
# └──────────────────────────────────────────────────────────────┘
# These are baked into the frontend at build time (Vite).
# The defaults work for the dev proxy setup.

VITE_API_BASE_URL=/api/v1
VITE_WS_URL=/ws


# ┌──────────────────────────────────────────────────────────────┐
# │  NETWORKING                                                  │
# └──────────────────────────────────────────────────────────────┘
# Host port for the nginx reverse proxy (production only).
# Change if port 80 is already in use on your host.

HTTP_PORT=80
