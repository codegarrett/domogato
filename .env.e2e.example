# E2E environment — copy values into root .env (read by docker compose) and/or export for Playwright.
# Usage:
#   1. Set LLM_* / EMBEDDING_* in .env (same as normal app — Ollama Cloud, OpenAI, etc.)
#   2. make e2e-up
#   3. cd frontend && npm run test:e2e

# App URLs (nginx preferred for prod-like routing)
E2E_BASE_URL=http://localhost
# E2E_BASE_URL=http://localhost:3035

# Credentials (must match backend/scripts/e2e_seed.py)
E2E_ADMIN_EMAIL=e2e-admin@domogato.test
E2E_ADMIN_PASSWORD=E2eAdmin!Pass123
E2E_USER_EMAIL=e2e-user@domogato.test
E2E_USER_PASSWORD=E2eUser!Pass123
E2E_GUEST_EMAIL=e2e-guest@domogato.test
E2E_GUEST_PASSWORD=E2eGuest!Pass123
E2E_REPORTER_EMAIL=e2e-reporter@domogato.test
E2E_REPORTER_PASSWORD=E2eReporter!Pass123
E2E_MAINTAINER_EMAIL=e2e-maintainer@domogato.test
E2E_MAINTAINER_PASSWORD=E2eMaintainer!Pass123

# LLM provider — same vars as the main app (.env). E2E compose passes these through to the API.
# Examples:
#   Ollama Cloud:
#     LLM_PROVIDER=ollama
#     LLM_MODEL=your-model
#     LLM_API_KEY=your-ollama-cloud-key
#     LLM_BASE_URL=https://ollama.com/v1
#     EMBEDDING_PROVIDER=ollama
#     EMBEDDING_MODEL=your-embedding-model
#     EMBEDDING_API_KEY=your-ollama-cloud-key
#     EMBEDDING_BASE_URL=https://ollama.com/v1
#   OpenAI:
#     LLM_PROVIDER=openai
#     LLM_MODEL=gpt-4o
#     LLM_API_KEY=sk-...
#     EMBEDDING_PROVIDER=openai
#     EMBEDDING_MODEL=text-embedding-3-small
#     EMBEDDING_API_KEY=sk-...
#
# Optional local Ollama container instead of cloud:
#   make e2e-up-local-ollama
#   LLM_BASE_URL=http://ollama:11434/v1
#   EMBEDDING_BASE_URL=http://ollama:11434/v1

# Test behaviour
E2E_SCREENSHOTS=only-on-failure
E2E_SKIP_AI=false
E2E_SKIP_RESET=false
E2E_UPDATE_SNAPSHOTS=0

# API URL for global-setup health checks (host-side)
E2E_API_URL=http://localhost/api/v1
