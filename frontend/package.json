{
  "name": "projecthub-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report e2e/playwright-report",
    "test:e2e:desktop": "playwright test --project=desktop-chrome",
    "test:e2e:mobile": "playwright test --project=mobile-chrome",
    "test:e2e:ai": "playwright test --project=ai-desktop e2e/ai",
    "test:e2e:layout": "playwright test --project=mobile-chrome e2e/layout",
    "test:a11y": "playwright test --project=unauthenticated e2e/a11y"
  },
  "dependencies": {
    "@primevue/themes": "^4.2.5",
    "axios": "^1.7.9",
    "chart.js": "^4.4.7",
    "dompurify": "^3.4.7",
    "marked": "^17.0.5",
    "oidc-client-ts": "^3.1.0",
    "pinia": "^2.3.0",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.2.5",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.2",
    "vue-i18n": "^11.3.0",
    "vue-router": "^4.5.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.1",
    "@tsconfig/node22": "^22.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.10.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-typescript": "^14.2.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0"
  }
}
