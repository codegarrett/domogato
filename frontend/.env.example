# API endpoints (use relative URLs when behind nginx/vite proxy)
VITE_API_BASE_URL=/api/v1
VITE_WS_URL=/ws

# OIDC / Keycloak (only needed when auth mode is set to oidc)
VITE_OIDC_AUTHORITY=https://keycloak.example.com/realms/projecthub
VITE_OIDC_CLIENT_ID=projecthub-frontend
VITE_OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000
